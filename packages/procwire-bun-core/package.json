{
  "name": "@procwire/bun-core",
  "version": "1.2.0",
  "description": "Core module system for Procwire binary protocol (Bun.js optimized).",
  "keywords": [
    "ipc",
    "module",
    "worker",
    "binary",
    "procwire",
    "bun",
    "typescript"
  ],
  "author": "Sebastian Webdev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianWebdev/procwire.git",
    "directory": "packages/procwire-bun-core"
  },
  "bugs": {
    "url": "https://github.com/SebastianWebdev/procwire/issues"
  },
  "homepage": "https://www.procwire.dev",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "bun": ">=1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist \"*.tsbuildinfo\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "test:ci": "bun test"
  },
  "dependencies": {
    "@procwire/protocol": "workspace:^",
    "@procwire/codecs": "workspace:^"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
