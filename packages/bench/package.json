{
  "name": "@procwire/bench",
  "version": "1.0.6",
  "description": "Benchmark suite for Procwire IPC library - real-world performance testing.",
  "keywords": [
    "benchmark",
    "performance",
    "ipc",
    "procwire",
    "throughput",
    "latency"
  ],
  "author": "Sebastian Webdev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianWebdev/procwire.git",
    "directory": "packages/bench"
  },
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./src/lib.ts",
      "default": "./src/lib.ts"
    }
  },
  "main": "./src/lib.ts",
  "types": "./src/lib.ts",
  "scripts": {
    "clean": "rimraf dist results \"*.tsbuildinfo\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "bench": "tsx --expose-gc src/index.ts",
    "bench:quick": "tsx --expose-gc src/index.ts --quick",
    "bench:bun": "bun --expose-gc run src/index.ts --runtime bun",
    "bench:bun:quick": "bun --expose-gc run src/index.ts --runtime bun --quick",
    "bench:compare": "tsx --expose-gc src/index.ts && bun --expose-gc run src/index.ts --runtime bun",
    "bench:lifecycle": "tsx --expose-gc src/lifecycle.ts",
    "bench:heartbeat": "tsx --expose-gc src/heartbeat.ts",
    "bench:backpressure": "tsx --expose-gc src/backpressure.ts"
  },
  "dependencies": {
    "@procwire/client": "workspace:*",
    "@procwire/codecs": "workspace:*",
    "@procwire/core": "workspace:*",
    "@procwire/bun-client": "workspace:*",
    "@procwire/bun-core": "workspace:*",
    "apache-arrow": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
