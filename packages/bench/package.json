{
  "name": "@procwire/bench",
  "version": "0.0.1",
  "description": "Benchmark suite for Procwire IPC library - real-world performance testing.",
  "keywords": [
    "benchmark",
    "performance",
    "ipc",
    "procwire",
    "throughput",
    "latency"
  ],
  "author": "Sebastian Webdev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianWebdev/procwire.git",
    "directory": "packages/bench"
  },
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist results \"*.tsbuildinfo\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "bench": "tsx src/index.ts",
    "bench:quick": "tsx src/index.ts --quick"
  },
  "dependencies": {
    "@procwire/client": "workspace:*",
    "@procwire/codecs": "workspace:*",
    "@procwire/core": "workspace:*",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
