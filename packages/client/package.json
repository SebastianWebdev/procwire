{
  "name": "@procwire/client",
  "version": "1.2.1",
  "description": "Child-side client for Procwire IPC",
  "keywords": [
    "ipc",
    "procwire",
    "client",
    "child-process"
  ],
  "author": "Sebastian Webdev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianWebdev/procwire.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/SebastianWebdev/procwire/issues"
  },
  "homepage": "https://www.procwire.dev",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist \"*.tsbuildinfo\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@procwire/protocol": "workspace:^",
    "@procwire/codecs": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
