{
  "name": "procwire-dashboard",
  "version": "1.0.2",
  "private": true,
  "description": "Benchmark dashboard for Procwire IPC library",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch src/server/index.ts\" \"cd client && pnpm dev\"",
    "server": "tsx src/server/index.ts",
    "server:dev": "tsx watch src/server/index.ts",
    "client:dev": "cd client && pnpm dev",
    "client:build": "cd client && pnpm build",
    "build": "pnpm client:build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist client/dist"
  },
  "dependencies": {
    "@procwire/bench": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^9.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
